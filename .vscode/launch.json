{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Vite + Debug Chrome (apps/web)",
            "type": "pwa-chrome",
            "request": "launch",
            "url": "http://localhost:13333",
            "webRoot": "${workspaceFolder}/apps/web",
            "preLaunchTask": "pnpm: dev (apps/web)",
            "breakOnLoad": true,
            "runtimeArgs": [
                "--remote-debugging-port=9222"
            ]
        },
        {
            "name": "Build & Preview + Debug Chrome (apps/web)",
            "type": "pwa-chrome",
            "request": "launch",
            "url": "http://localhost:13333",
            "webRoot": "${workspaceFolder}/apps/web",
            "preLaunchTask": "pnpm: build+preview (apps/web)",
            "breakOnLoad": true,
            "runtimeArgs": [
                "--remote-debugging-port=9222"
            ]
        }
    ]
}